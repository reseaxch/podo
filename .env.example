PODO_CORE_HOST=127.0.0.1
PODO_CORE_PORT=4100
PODO_CORE_URL=http://127.0.0.1:4100
# Dashboard defaults for the hosted/Vercel fixture build. For a self-hosted
# Core-backed dashboard, set PODO_DASHBOARD_MODE=live and keep PODO_CORE_URL
# reachable from the Dashboard server process.
PODO_DASHBOARD_MODE=demo
# The contextual Agent intentionally remains a local browser demo. Do not set
# this to live until its Core-backed UX is ready to ship.
NEXT_PUBLIC_PODO_AGENT_MODE=demo
CODEX_BIN=codex
PODO_AGENT_CHAT_ENABLED=false
# Required only when PODO_AGENT_CHAT_ENABLED=true. The path is resolved to one
# canonical existing directory before Core starts listening.
# PODO_AGENT_CHAT_CWD=/absolute/path/to/repository
PODO_REMEDIATION_ENABLED=false
# Required only when PODO_REMEDIATION_ENABLED=true. Commands are JSON argv
# arrays; shell command strings are rejected.
# PODO_REMEDIATION_REPOSITORY_ROOT=/absolute/path/to/repository
# PODO_REMEDIATION_BASE_REF=refs/remotes/origin/main
# PODO_REMEDIATION_PULL_REQUEST_BASE_BRANCH=main
# PODO_REMEDIATION_SCRATCH_PARENT=/absolute/path/to/worktrees
# PODO_REMEDIATION_REGRESSION_COMMAND=["bun","test","demo/services/checkout-service"]
# PODO_REMEDIATION_VALIDATION_COMMANDS=[["bun","run","typecheck"],["bun","test"]]
# PODO_REMEDIATION_COMMAND_TIMEOUT_MS=120000
# PODO_REMEDIATION_TURN_TIMEOUT_MS=90000
# PODO_REMEDIATION_MAX_OUTPUT_BYTES=524288
PODO_GITHUB_DELIVERY_ENABLED=false
PODO_GITHUB_ISSUE_ENABLED=false
# Issue fallback needs only PODO_GITHUB_TOKEN and PODO_GITHUB_REPOSITORY. It
# creates an evidence-backed issue and never publishes a branch or patch.
# Required only when PODO_GITHUB_DELIVERY_ENABLED=true. The repository root,
# scratch parent, and pull-request base branch come from the remediation config
# above so delivery cannot target a different checkout or base branch.
# PODO_GITHUB_TOKEN=github_token
# PODO_GITHUB_REPOSITORY=owner/repository
# PODO_GITHUB_DEFAULT_BRANCH=main
# PODO_GITHUB_OPERATOR_IDENTITY=local-operator
# PODO_GITHUB_REMOTE_NAME=origin
# PODO_GITHUB_COMMAND_TIMEOUT_MS=120000
# PODO_GITHUB_MAX_OUTPUT_BYTES=524288
